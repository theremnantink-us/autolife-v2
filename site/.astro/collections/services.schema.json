{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "Мойка",
        "Детейлинг",
        "Шиномонтаж"
      ]
    },
    "price_from": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "price_to": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "duration_hours": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "warranty_months": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "materials": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hero_image": {
      "type": "string"
    },
    "short_description": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "slug",
    "name",
    "category",
    "price_from",
    "duration_hours",
    "hero_image",
    "short_description",
    "order"
  ]
}