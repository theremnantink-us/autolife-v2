---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}
const {
  title = 'АвтоЛайф — Мойка, Детейлинг, Шиномонтаж на Рублёво-Успенском шоссе',
  description = 'Автокомплекс АвтоЛайф — профессиональная мойка, детейлинг и шиномонтаж на Рублево-Успенском шоссе. Качественные услуги для вашего автомобиля.',
  ogImage = '/IMG/og-cover.jpg',
  noIndex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://autolife.ru').toString();
---
<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#08090b" />
  <meta name="format-detection" content="telephone=no" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="автомойка, детейлинг, шиномонтаж, полировка, химчистка, керамика, Москва, Рублевка, автосервис, AutoLife, АвтоЛайф" />
  <link rel="canonical" href={canonical} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://autolife.ru').toString()} />
  <meta property="og:site_name" content="АвтоЛайф" />

  <!-- Security headers (meta-equiv where supported; full set added by webserver) -->
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <!-- CSP via meta — restrictive baseline; full nonce-based CSP enforced server-side. -->
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self' data: blob: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://api-maps.yandex.ru https://yastatic.net https://www.gstatic.com; worker-src 'self' blob:; media-src 'self' data:; connect-src 'self' blob: data: https://api.telegram.org https://search-maps.yandex.ru https://yandex.ru https://www.gstatic.com https://*.supabase.co wss://*.supabase.co; frame-src 'self' https://yandex.ru https://api-maps.yandex.ru; object-src 'none'; base-uri 'self'; form-action 'self';" />

  <!-- Favicons & PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/IMG/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/IMG/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/IMG/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />

  <!-- Fonts (preconnect) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Draco WASM decoder (used by GLB loader) -->
  <link rel="preconnect" href="https://www.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.gstatic.com" />
  <!-- Yandex -->
  <link rel="preconnect" href="https://yandex.ru" />
  <link rel="preconnect" href="https://yastatic.net" crossorigin />
  <link rel="dns-prefetch" href="https://yandex.ru" />
  <link rel="dns-prefetch" href="https://yastatic.net" />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Michroma&family=Montserrat:wght@500;600;700&family=Orbitron:wght@600;700;800;900&display=swap"
  />

  <!-- Structured data: LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'AutoWash',
    name: 'АвтоЛайф',
    description,
    url: canonical,
    image: new URL(ogImage, Astro.site ?? 'https://autolife.ru').toString(),
    telephone: '+7-903-555-10-55',
    email: 'avtolive@gmail.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Рублево-Успенское шоссе, п. Горки-10, строение 31А',
      addressLocality: 'Москва',
      addressCountry: 'RU',
    },
    openingHoursSpecification: [
      { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '09:00', closes: '21:00' },
      { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday','Sunday'], opens: '10:00', closes: '20:00' },
    ],
  })} />
</head>
<body>
  <a href="#main" class="skip-link">Перейти к содержимому</a>
  <slot name="header" />
  <main id="main">
    <slot />
  </main>
  <slot name="footer" />

  <!-- Lenis smooth scroll + GSAP ScrollTrigger sync + visit tracking -->
  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Always register ScrollTrigger so islands can use it
    gsap.registerPlugin(ScrollTrigger);

    if (!reduced) {
      const lenis = new Lenis({
        duration: 1.1,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        touchMultiplier: 1.5,
      });
      // Drive Lenis from GSAP's RAF — single tick loop, perfect ScrollTrigger sync
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      (window as any).__lenis = lenis;
    } else {
      // Plain ScrollTrigger still works without Lenis
      ScrollTrigger.refresh();
    }

    // Cinematic timeline driver: a single ScrollTrigger spanning the whole
    // <body> exposes `window.__heroProgress` (0→1) for the R3F canvas to
    // consume via useFrame. This replaces the per-component scroll listeners
    // and gives us scrubbing + onUpdate hooks for free.
    ScrollTrigger.create({
      trigger: 'body',
      start: 'top top',
      end: 'bottom bottom',
      onUpdate: (self) => {
        (window as any).__heroProgress = self.progress;
        window.dispatchEvent(new CustomEvent('autolife:hero-progress', { detail: self.progress }));
      },
    });

    // Hero-specific reveal — drives several CSS variables off scroll:
    //   --hero-blur     : 28px → 0   (frosted-glass clears quickly)
    //   --hero-sat      : 0.55 → 1   (saturation rebounds with the blur)
    //   --hero-text-op  : 1 → 0.45   (hero copy fades back so the car can
    //                                 emerge in front without a hard cut)
    // Plus a class .hero-foreground that pushes the canvas above the hero
    // text via z-index. The class flip is timed to the middle of the text
    // fade so it isn't visually noticeable.
    const heroReveal = document.querySelector('.hero') as HTMLElement | null;
    if (heroReveal) {
      // ease-out cubic — fast at start, slow at end; feels organic
      const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
      // smooth step — S-curve, used to taper the text-fade nicely
      const smooth = (t: number) => t * t * (3 - 2 * t);

      ScrollTrigger.create({
        trigger: heroReveal,
        start: 'top top',
        end: 'bottom top',
        scrub: 0.4,                   // adds inertia → smoother scrub
        onUpdate: (self) => {
          const p = self.progress;

          // Blur clears over the first 12% of scroll, eased.
          const tBlur  = Math.min(1, p / 0.12);
          const blur   = 28 * (1 - easeOut(tBlur));

          // Saturation rebounds in lockstep with the blur fade.
          const sat    = 0.55 + (1 - 0.55) * easeOut(tBlur);

          // Hero text dims through the band where the canvas lifts.
          // Fade range 0.10 → 0.30 of scroll; never below 0.45 so it
          // remains legible.
          const tText  = Math.max(0, Math.min(1, (p - 0.10) / 0.20));
          const textOp = 1 - smooth(tText) * 0.55;

          const root = document.documentElement;
          root.style.setProperty('--hero-blur',     blur.toFixed(2) + 'px');
          root.style.setProperty('--hero-sat',      sat.toFixed(3));
          root.style.setProperty('--hero-text-op',  textOp.toFixed(3));

          // Z-swap fires in the middle of the text-fade band → masked.
          root.classList.toggle('hero-foreground', p > 0.20 && p < 0.92);
        },
      });
    }

    // Visit tracking (best-effort, fires once). Skipped in dev where the
    // PHP backend isn't running on the Vite port — saves a noisy 404.
    if (import.meta.env.PROD) {
      try {
        const url = '/track_visit.php';
        navigator.sendBeacon
          ? navigator.sendBeacon(url)
          : fetch(url, { method: 'POST', keepalive: true, credentials: 'same-origin' });
      } catch { /* noop */ }
    }
  </script>
</body>
</html>
