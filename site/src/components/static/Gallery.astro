---
import GalleryIsland from '../islands/GalleryIsland.tsx';

/* Bento gallery — items come from Supabase (editable in the admin panel),
   with a static fallback. Rendered as a client island so edits go live
   without a rebuild. */
---
<section class="gal" id="gallery" aria-labelledby="gallery-heading">
  <div class="container">
    <header class="section__head gal__head">
      <p class="eyebrow">Галерея</p>
      <h2 id="gallery-heading" class="section__title">Работы из бокса</h2>
      <p class="section__lead">
        Реальные автомобили и реальные результаты. Кликните по фото — откроется крупно с навигацией.
      </p>
    </header>

    <GalleryIsland client:visible />
  </div>
</section>

<style>
  .gal {
    position: relative;
    z-index: 2;
    padding-block: var(--space-9);
    background: transparent;
  }
  .gal__head { max-width: 60ch; margin-bottom: var(--space-6); }
</style>

