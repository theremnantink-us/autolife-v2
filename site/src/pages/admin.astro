---
/**
 * /admin — admin panel shell.
 *
 * Авторизация — Supabase Auth (email + password).
 * AdminApp проверяет сессию на клиенте и показывает форму входа если не авторизован.
 *
 * Заголовки безопасности: X-Frame-Options, CSP, HSTS и др. — выставлены ниже.
 * DDoS-защита: Cloudflare на уровне CDN (рекомендуется), rate limiting в api.php.
 */
import Base from '../layouts/Base.astro';
import Header from '../components/static/Header.astro';
import AdminApp from '../components/islands/admin/AdminApp';

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseHost = SUPABASE_URL ? new URL(SUPABASE_URL).host : '*.supabase.co';

// Security headers — выставляем на каждый ответ /admin
Astro.response.headers.set('X-Frame-Options', 'DENY');
Astro.response.headers.set('X-Content-Type-Options', 'nosniff');
Astro.response.headers.set('Referrer-Policy', 'no-referrer');
Astro.response.headers.set('Permissions-Policy', 'geolocation=(), microphone=(), camera=(), payment=(), usb=()');
Astro.response.headers.set('Cross-Origin-Opener-Policy', 'same-origin');
Astro.response.headers.set('Cross-Origin-Resource-Policy', 'same-origin');
Astro.response.headers.set(
  'Content-Security-Policy',
  [
    "default-src 'self'",
    "script-src 'self' 'unsafe-inline' 'unsafe-eval'",   // React hydration (Astro client:only)
    "style-src 'self' 'unsafe-inline'",
    "img-src 'self' data: https:",
    `connect-src 'self' https://${supabaseHost} wss://${supabaseHost}`,
    "frame-ancestors 'none'",
    "form-action 'self'",
    "base-uri 'self'",
    "object-src 'none'",
  ].join('; '),
);

const title = 'Админ-панель — АвтоЛайф';
const description = 'Внутренний раздел: записи, календарь, зарплаты, авансы.';
---
<Base title={title} description={description} noIndex>
  <Header slot="header" />

  <main class="admin-main" id="main">
    <div class="container admin-shell">
      <AdminApp client:only="react" />
    </div>
  </main>
</Base>

<style>
  .admin-main {
    /* Solid, non-3D background — admin must read like a tool, not a hero. */
    min-height: 100vh;
    padding-block: var(--space-6);
    background:
      radial-gradient(ellipse at 60% 0%, rgba(232,234,237,0.06) 0%, transparent 60%),
      linear-gradient(180deg, #0a0c10 0%, #08090b 100%);
  }
  .admin-shell {
    padding-top: var(--space-3);
  }
</style>
