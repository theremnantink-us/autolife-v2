# ============================================================
# autolife-detail.ru — Apache config
# ============================================================

RewriteEngine On

# --- Maintenance mode ----------------------------------------
# ВКЛЮЧИТЬ: убери знак # с двух строк ниже (включает заглушку для всех)
# ОТКЛЮЧИТЬ: поставь # обратно
#
# Для доступа админу: впиши свой IP в третью строку (узнать на 2ip.ru)
# и убери # со всех трёх строк сразу.
#
#RewriteCond %{REQUEST_URI} !^/maintenance\.html$
#RewriteCond %{REQUEST_URI} !\.(css|js|png|jpe?g|svg|webp|ico|woff2?)$
#RewriteCond %{REMOTE_ADDR} !^123\.45\.67\.89$
#RewriteRule ^(.*)$ /maintenance.html [R=302,L]

# --- Force HTTPS ---------------------------------------------
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Deny any dotfile (.env, .git, etc.) ---
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# --- Deny dev / admin scripts ---
<FilesMatch "^(test_|check_|create_|db_status|generate-vapid).*\.php$">
  Require all denied
</FilesMatch>
<Files "admin.php">
  Require all denied
</Files>

# --- Security headers ---
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-site"
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://api-maps.yandex.ru https://yastatic.net https://www.gstatic.com; worker-src 'self' blob:; media-src 'self' data:; connect-src 'self' blob: data: https://api.telegram.org https://search-maps.yandex.ru https://yandex.ru https://www.gstatic.com https://*.supabase.co wss://*.supabase.co; frame-src 'self' https://yandex.ru https://api-maps.yandex.ru; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>

# --- Root: serve dist/index.html directly ---
RewriteRule ^$ /dist/index.html [L]

# --- Serve Astro build from /dist/ for non-PHP requests ---
# All requests not already in /dist/, not PHP, not blocked, and not
# a real file at root → rewrite to /dist/$1.
# IMG/, icons/, _astro/, models/, hdri/ live INSIDE dist/, so they
# must NOT be excluded here (excluding them caused 404s for assets).
RewriteCond %{REQUEST_URI} !^/dist/
RewriteCond %{REQUEST_URI} !\.php$
RewriteCond %{REQUEST_URI} !\.(env|htaccess|ini|log)$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ /dist/$1 [L]

# --- Directory index ---
DirectoryIndex index.html index.php

# --- Brotli compression (when available — Timeweb has Apache 2.4+ with mod_brotli) ---
# Brotli is ~15-20% better than gzip on text. mod_deflate stays as fallback.
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# --- Gzip for text assets (fallback when Brotli isn't supported) ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# --- Long cache + immutable for hashed Astro build artifacts ----
# /_astro/*.js, *.css have content hashes in their filename, safe to cache forever.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(webp|jpe?g|png|gif|svg|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
  # HTML must NOT be cached aggressively — we deploy new HTML on every release
  <FilesMatch "\.html?$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# --- ExpiresByType as fallback for clients that don't honor Cache-Control ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css   "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff  "access plus 1 year"
  ExpiresByType text/html  "access plus 5 minutes"
</IfModule>
