; autolife-detail.ru — environment template
; Copy to public_html/.env on the server, fill in real values, chmod 600.
; NEVER commit the real .env — it is in .gitignore.

; --- Database (Timeweb MySQL) ---
DB_HOST=localhost
DB_NAME=ct50507_autolife
DB_USER=ct50507_autolife
DB_PASS=CHANGE_ME

; --- Telegram notifications ---
; Get a fresh token from @BotFather → /revoke → /token
TG_BOT_TOKEN=CHANGE_ME
TG_CHAT_ID=CHANGE_ME

; --- CORS + rate limiting ---
CORS_ORIGIN=https://autolife-detail.ru
RATE_LIMIT_BOOKING_PER_HOUR=5
RATE_LIMIT_FEEDBACK_PER_HOUR=3

; --- App ---
APP_ENV=production
APP_URL=https://autolife-detail.ru
